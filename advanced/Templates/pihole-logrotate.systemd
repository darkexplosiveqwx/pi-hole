[Unit]
Description=Pi-hole logrotate
After=local-fs.target
Requires=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/sbin/logrotate --state /var/lib/logrotate/pihole /etc/pihole/logrotate

ProtectSystem=full
ReadWriteDirectories=/etc/pihole
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
RestrictSUIDSGID=yes
UMask=0077
LockPersonality=yes

[Install]
WantedBy=multi-user.target
