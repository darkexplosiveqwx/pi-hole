# Pi-hole: Grab remote and local version every 24 hours
[Unit]
Description=Pi-hole updatechecker
After=network-online.target nss-lookup.target

[Service]
Type=oneshot
User=root
ExecStart=/usr/bin/bash -c 'PATH="$PATH:/usr/sbin:/usr/local/bin/" pihole updatechecker'

ProtectSystem=full
ReadWriteDirectories=/etc/pihole
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
RestrictSUIDSGID=yes
UMask=0077
LockPersonality=yes
